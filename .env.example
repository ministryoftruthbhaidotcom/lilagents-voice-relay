# Copy this file to ".env" and fill in your real values. NEVER commit .env.

# Your Google Gemini API key — the ONLY place it lives. Stays on the server.
# Get one free at https://aistudio.google.com/apikey (the Live API has a free tier).
GEMINI_API_KEY=AIza...

# Port the relay listens on (most hosts set PORT automatically).
PORT=8787

# Gemini Live model with native audio (most natural, emotional voice).
LIVE_MODEL=gemini-3.1-flash-live-preview

# Per-character prebuilt voices (Gemini built-ins: Aoede, Charon, Kore, Puck, Fenrir, …).
VOICE_JOSH=Charon
VOICE_HOPE=Aoede

# Optional quick-test codes (comma-separated). For real use, manage codes.json instead.
# INVITE_CODES=TEST-1234,DEMO-5678

# The exclusive build's download link, revealed by /verify when a code checks out.
EXCLUSIVE_DOWNLOAD_URL=https://github.com/ministryoftruthbhaidotcom/lilagents-app/releases/latest/download/LilAgents-pro-bundle.zip

# Comma-separated browser origins allowed to call /verify (your website). Leave blank
# to allow any origin. Example: https://lilagents.app,https://www.lilagents.app
ALLOWED_ORIGINS=
